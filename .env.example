# Environment Configuration for Physics Database
# Copy this file to .env and update the values

# Required: Flask secret key for session security
SECRET_KEY=your-secret-key-here-change-in-production

# Enable debug mode for local development only. Remove or set to 0 in production.
# (FLASK_ENV is deprecated in Flask 2.x)
FLASK_DEBUG=1

# Database (optional - defaults to SQLite at instance/physdb.db)
# Leave unset for SQLite (recommended for most deployments)
# For MySQL:      DATABASE_URL=mysql+pymysql://username:password@localhost/physdb
# For PostgreSQL: DATABASE_URL=postgresql://username:password@localhost/physdb
